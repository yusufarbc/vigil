# =============================================================================
# Sentinel — Environment Variables Reference
# Copy this file to .env and fill in the values.
# .env is git-ignored. Never commit real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Elasticsearch (shared by detection-service, case-service, enrichment-service)
# ---------------------------------------------------------------------------
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=changeme
ELASTIC_CA_CERTS=                           # path to CA cert (leave empty for local dev)

# ---------------------------------------------------------------------------
# GCP / Pub/Sub
# ---------------------------------------------------------------------------
GCP_PROJECT=sentinel-local
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085   # set to empty in production (uses real Pub/Sub)

# Pub/Sub topics (must exist before services start — see make pubsub-init)
ALERTS_TOPIC=sentinel.alerts
INCIDENTS_TOPIC=sentinel.incidents
MASKED_INCIDENTS_TOPIC=sentinel.masked-incidents
TRIAGE_DECISIONS_TOPIC=sentinel.triage-decisions
DLQ_TOPIC=sentinel.dlq

# Pub/Sub subscriptions
ALERTS_SUBSCRIPTION=sentinel.alerts.gateway-sub
INCIDENTS_SUBSCRIPTION=sentinel.incidents.enrichment-sub
MASKED_INCIDENTS_SUBSCRIPTION=sentinel.masked-incidents.llm-sub
TRIAGE_DECISIONS_SUBSCRIPTION=sentinel.triage-decisions.case-sub

# ---------------------------------------------------------------------------
# LLM Orchestrator
# ---------------------------------------------------------------------------
# "mock" = no API calls, safe for CI and local dev
# "vertex" = Gemini via Vertex AI (requires GCP_PROJECT + Workload Identity or GOOGLE_APPLICATION_CREDENTIALS)
LLM_PROVIDER=mock
LLM_MODEL_ID=gemini-2.5-flash              # model ID; never hard-code in code
VERTEX_LOCATION=us-central1

# Budget circuit-breaker: max tokens per reset window
LLM_MAX_TOKENS_PER_WINDOW=500000

# ---------------------------------------------------------------------------
# Service URLs (used by enrichment-service and case-service to call masking-service)
# ---------------------------------------------------------------------------
MASKING_SERVICE_URL=http://masking-service:8001
CASE_SERVICE_URL=http://case-service:8002

# ---------------------------------------------------------------------------
# Alert Gateway
# ---------------------------------------------------------------------------
# How many correlated alerts form an incident (threshold-based flush)
CORRELATION_THRESHOLD=5

# ---------------------------------------------------------------------------
# BFF
# ---------------------------------------------------------------------------
LISTEN_ADDR=:8080

# ---------------------------------------------------------------------------
# Kibana (production — ECK sets these; local dev uses kibana.yml)
# ---------------------------------------------------------------------------
KIBANA_ENCRYPTION_KEY=                      # 32-char random string
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# ---------------------------------------------------------------------------
# GCS Snapshots (production only — ADR-010)
# ---------------------------------------------------------------------------
GCS_BUCKET=sentinel-es-snapshots
GCS_SNAPSHOT_RETENTION=2y

# ---------------------------------------------------------------------------
# Logstash (baremetal / VM install)
# ---------------------------------------------------------------------------
# These are injected via Logstash keystore in production (see elk_setup_ubuntu_jammy.sh)
# LOGSTASH_ELASTIC_PASSWORD=               # set via keystore, never here
